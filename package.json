{
  "name": "senm",
  "version": "0.1.0",
  "private": true,
  "description": "Desktop prompt translator for turning short-drama scripts into Seedance 2.0 video generation prompts.",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"vite --host 127.0.0.1\" \"wait-on http://127.0.0.1:5173 && cross-env VITE_DEV_SERVER_URL=http://127.0.0.1:5173 electron .\"",
    "start": "npm run dev",
    "build": "tsc --noEmit && vite build",
    "test": "vitest run --config vitest.config.ts",
    "test:credentials": "node --test tests/credential-store.test.cjs",
    "preview": "vite preview --host 127.0.0.1",
    "electron": "electron .",
    "dist:mac": "npm run build && electron-builder --mac --arm64 --dir --publish never && node scripts/ad-hoc-sign-mac.cjs && electron-builder --mac dmg zip --arm64 --prepackaged release/mac-arm64 --publish never",
    "dist:win": "npm run build && electron-builder --win nsis zip --x64 --publish never"
  },
  "keywords": [
    "seedance",
    "prompt",
    "short-drama",
    "electron",
    "macos",
    "windows"
  ],
  "author": "Git_Nako",
  "license": "MIT",
  "homepage": "https://github.com/lareeyoung/SENM#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lareeyoung/SENM.git"
  },
  "bugs": {
    "url": "https://github.com/lareeyoung/SENM/issues"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "cross-env": "^7.0.3",
    "electron-store": "^8.2.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "typescript": "^5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.see2p.transfer",
    "productName": "SENM",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/renderer/**/*",
      "electron/**/*",
      "package.json"
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.icns",
      "extendInfo": {
        "LSUIElement": true
      },
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "icon": "build/icon.ico",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "SENM",
      "uninstallDisplayName": "SENM"
    }
  }
}
